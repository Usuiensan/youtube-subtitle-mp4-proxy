CACHE_DIR=/var/cache/youtube-mp4
# Optional two-tier cache. Use CACHE_HOT_DIR on SSD and CACHE_ARCHIVE_DIR on HDD.
# CACHE_HOT_DIR=/mnt/ssd/youtube-mp4-hot
# CACHE_ARCHIVE_DIR=/mnt/hdd/youtube-mp4-archive
# CACHE_ARCHIVE_AFTER_SECONDS=604800
# CACHE_HOT_MIN_FREE_BYTES=50000000000
# CACHE_PROMOTE_ARCHIVE_ON_ACCESS=1
DEFAULT_LANG=ja
MAX_DURATION_SECONDS=3600
MAX_HEIGHT=720
CACHE_TTL_SECONDS=604800
JOB_TIMEOUT_SECONDS=7200
HLS_SEGMENT_SECONDS=6
HLS_READY_TIMEOUT_SECONDS=1800
FFMPEG_VIDEO_ENCODER=libx264
FFMPEG_VIDEO_PRESET=veryfast
FFMPEG_VIDEO_CRF=23
# For NVIDIA GTX 1050 Ti / NVENC:
# FFMPEG_VIDEO_ENCODER=h264_nvenc
# FFMPEG_VIDEO_PRESET=fast
# FFMPEG_VIDEO_CQ=23
YTDLP_COOKIES_FILE=/etc/youtube-mp4-cookies.txt
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PREPARE_TOKEN=change-this-token
WEBUI_TEMP_KEY_SECRET=change-this-webui-temp-key-secret

# System monitoring shown on the Web UI Monitor tab.
SYSTEM_METRICS_ENABLED=1
SYSTEM_METRICS_INTERVAL_SECONDS=5
SYSTEM_METRICS_HISTORY_SECONDS=86400
# SYSTEM_METRICS_FILE=/var/lib/youtube-mp4-proxy/system-metrics.jsonl
YOUTUBE_PROXY_BASE_URL=https://lab.usuiensan.dev
YOUTUBE_PROXY_INTERNAL_BASE_URL=http://127.0.0.1:8000
DISCORD_PREPARE_POLL_SECONDS=10
DISCORD_PREPARE_POLL_TIMEOUT_SECONDS=7200
DISCORD_PREPARE_BATCH_MAX_ITEMS=5000
TRANSLATION_ENABLED=1
TRANSLATION_SOURCE_LANGS=en,ko,zh-Hans,zh-Hant,zh,zh-CN,zh-TW
TRANSLATION_PROVIDER=nllb
TRANSLATION_FALLBACK_ENGINE=google_cloud
LOCAL_LLM_ENGINE=openai_compatible
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
LOCAL_LLM_MODEL=qwen2.5:3b-instruct-q4_K_M
LOCAL_LLM_MODEL_GEMINI_2_5_FLASH=gemini-2.5-flash
LOCAL_LLM_MODEL_QWEN3_1_7B=qwen3:1.7b
LOCAL_LLM_MODEL_GEMMA3_1B=gemma3:1b
LOCAL_LLM_MODEL_GEMMA3_4B=gemma3:4b
LOCAL_LLM_MODEL_NLLB200_DISTILLED_600M=facebook/nllb-200-distilled-600M
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BILLING_MODE=free_tier
GEMINI_FLASH_INPUT_PRICE_PER_MILLION=0.30
GEMINI_FLASH_OUTPUT_PRICE_PER_MILLION=2.50
USD_TO_JPY_RATE=160.0
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_DEVICE=auto
NLLB_BATCH_SIZE=16
NLLB_MAX_INPUT_TOKENS=512
NLLB_MAX_NEW_TOKENS=128
NLLB_NUM_BEAMS=1
NLLB_KEEP_LOADED=1
HF_HOME=/mnt/youtube-archive/ai-cache/huggingface
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
LOCAL_LLM_TIMEOUT_SECONDS=300
LOCAL_LLM_TARGET_WINDOW_SECONDS=120
LOCAL_LLM_TARGET_MAX_EVENTS=10
# LOCAL_LLM_CONTEXT_SECONDS=120
LOCAL_LLM_CONTEXT_BEFORE_SECONDS=120
LOCAL_LLM_CONTEXT_BEFORE_MAX_EVENTS=25
LOCAL_LLM_CONTEXT_AFTER_SECONDS=120
LOCAL_LLM_CONTEXT_AFTER_MAX_EVENTS=25
LOCAL_LLM_MAX_OUTPUT_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0
# GOOGLE_APPLICATION_CREDENTIALS=/etc/youtube-mp4-google-credentials.json
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# Required for /prepare/youtube-batch, /yamaplayer/playlist, and /yamaplayer/channel.
YOUTUBE_DATA_API_KEY=your-youtube-data-api-key
SUBTITLE_FONT=BIZ UDPGothic
SUBTITLE_FONT_SIZE=20
Shadow = 1
SUBTITLE_MARGIN_V=34
SUBTITLE_MARGIN_L=24
SUBTITLE_MARGIN_R=24
SUBTITLE_PRIMARY_COLOUR=&H00FFFFFF
SUBTITLE_BACK_COLOUR=&H40000000
