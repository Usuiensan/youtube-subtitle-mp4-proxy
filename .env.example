CACHE_DIR=/var/cache/youtube-mp4
DEFAULT_LANG=ja
MAX_DURATION_SECONDS=3600
MAX_HEIGHT=720
CACHE_TTL_SECONDS=604800
JOB_TIMEOUT_SECONDS=7200
HLS_SEGMENT_SECONDS=6
HLS_READY_TIMEOUT_SECONDS=1800
FFMPEG_VIDEO_ENCODER=libx264
FFMPEG_VIDEO_PRESET=veryfast
FFMPEG_VIDEO_CRF=23
# For NVIDIA GTX 1050 Ti / NVENC:
# FFMPEG_VIDEO_ENCODER=h264_nvenc
# FFMPEG_VIDEO_PRESET=fast
# FFMPEG_VIDEO_CQ=23
YTDLP_COOKIES_FILE=/etc/youtube-mp4-cookies.txt
# Required for /yamaplayer/playlist and /yamaplayer/channel.
YOUTUBE_DATA_API_KEY=your-youtube-data-api-key
SUBTITLE_FONT=BIZ UDGothic
SUBTITLE_FONT_SIZE=20
Shadow = 1
SUBTITLE_MARGIN_V=34
SUBTITLE_MARGIN_L=24
SUBTITLE_MARGIN_R=24
SUBTITLE_PRIMARY_COLOUR=&H00FFFFFF
SUBTITLE_BACK_COLOUR=&H40000000
# Set this for private use, then send it as X-Api-Key.
# API_KEY=change-me
